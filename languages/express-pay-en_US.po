#: src/class.expresspay.payment.php:233
msgid "epos-payment-success-message"
msgstr ""
"<h3>Account added to the E-POS system for payment</h3>\n"
"\t\t\t\t<h4>Your order number: ##epos_code##</h4>\n"
"\t\t\t\t<table style=\"width: 100%;text-align: left;\"><tbody><tr><td "
"valign=\"top\" style=\"text-align:left;\">\n"
"\t\t\t\tYou need to make a payment in any system that allows you to pay "
"through ERIP (banking service points, \n"
"\t\t\t\tATMs, payment terminals, Internet banking systems, client banking, "
"etc.).\n"
"\t\t\t\t<br/> 1. To do this, in the list of ERIP services, go to the section:"
" <b> Settlement System (ERIP)\n"
"\t\t\t\t -&gt; E-POS Service-&gt; E-POS - payment for goods and services</b>"
"\n"
"\t\t\t\t <br/>2. In the Code field, enter <b>##epos_code##</b> and click "
"\"Continue\"\n"
"\t\t\t\t <br/>3. Check the correctness of the information\n"
"\t\t\t\t <br/>4. Make a payment.</td>\n"
"\t\t\t\t <td style=\"text-align: center;padding: 40px 20px 0 0;vertical-"
"align: middle\">\n"
"\t\t\t\t <p>##qr_code##</p><p><b>Scan the QR code to pay</b></p></td></tr>"
"</tbody></table>"

#: src/class.expresspay.payment.php:193
msgid "erip-payment-success-message"
msgstr ""
"<h3>Account added to the ERIP system for payment</h3>\n"
"        <h4>Your order number: ##order_id##</h4>\n"
"        <table style=\"width: 100%;text-align: left;\"><tbody><tr><td "
"valign=\"top\" style=\"text-align:left;\">\n"
"        You need to make a payment in any system that allows you to pay "
"through ERIP (items banking services, ATMs,\n"
"        payment terminals, Internet banking systems, client banking, etc.).\n"
"        <br/> 1. To do this, in the list of ERIP services go to the section:"
"<br/><b>##erip_path##</b>\n"
"        <br/> 2. Next, enter the order number <b>##order_id##</b> and click "
"\"Continue\"\n"
"        <br/> 3. Check if the information is correct. \n"
"        <br/> 4. Make a payment.</td> </tbody></table>"

